<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.yourname.lifetracker.ui.home.HomeFragment"
        android:label="Home">
        <!-- Action to go to detail screen -->
        <action
            android:id="@+id/action_home_to_detail"
            app:destination="@id/habitDetailFragment"/>
    </fragment>

    <fragment
        android:id="@+id/statsFragment"
        android:name="com.yourname.lifetracker.ui.stats.StatsFragment"
        android:label="Stats"/>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.yourname.lifetracker.ui.settings.SettingsFragment"
        android:label="Settings"/>

    <fragment
        android:id="@+id/habitDetailFragment"
        android:name="com.yourname.lifetracker.ui.detail.HabitDetailFragment"
        android:label="Habit Detail">
        <!-- Argument passed from HomeFragment -->
        <argument
            android:name="habitId"
            app:argType="integer"/>
    </fragment>

</navigation>